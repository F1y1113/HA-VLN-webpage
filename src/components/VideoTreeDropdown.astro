---
import videoData from '../data/video-data.json';
import categoryData from '../data/category.json';

interface Props {
  className?: string;
  dd: string;
  mp4: string;
  png: string;
}

const { className = "", png, mp4 } = Astro.props;
---

<div class={`video-tree-dropdown ${className}`}>
  <!-- 水平排列的树形下拉菜单 -->
  <div class="flex justify-start mb-6">
    <div class="bg-white rounded-lg shadow-lg p-4" style="width: 100%;">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Explore the Simulator</h3>
      
      <!-- 水平排列的选择器和按钮 -->
      <div class="flex gap-4 items-end">
        <!-- 一级文件夹下拉 -->
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 mb-1">Scan id:</label>
          <select id="folder-select" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Please select a Scan id</option>
            {videoData.folders.map((folder) => (
              <option value={folder.name}>{folder.name}</option>
            ))}
          </select>
        </div>

        <!-- 二级子文件夹下拉 -->
        <div id="subfolder-container" class="flex-1">
          <label class="block text-sm font-medium text-gray-700 mb-1">Human id:</label>
          <select id="subfolder-select" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Please select a Human id</option>
          </select>
        </div>

        <!-- Submit按钮 -->
        <div id="submit-container" class="flex-shrink-0">
          <button 
            id="submit-btn" 
            class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:bg-gray-400 disabled:cursor-not-allowed transition-colors"
            disabled
          >
            Submit
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- 多视频显示区域 -->
  <div id="video-display" class="hidden">
    <div class="bg-white rounded-lg shadow-lg p-6" style="width: 100%;">
      <!-- 标题显示 -->
      <div class="mb-4">
        <h2 id="video-section-title" class="text-xl font-bold text-gray-800"></h2>
      </div>
      
      <!-- 多视频播放器容器 -->
      <div id="video-players-container" class="grid gap-4">
        <!-- 动态生成的视频播放器将插入这里 -->
      </div>
    </div>
  </div>
</div>

<script define:vars={{ videoData, categoryData, mp4, png }}>
    console.log('======mp4', mp4);
     console.log('======png', png);
  document.addEventListener('DOMContentLoaded', function() {
    const folderSelect = document.getElementById('folder-select');
    const subfolderContainer = document.getElementById('subfolder-container');
    const subfolderSelect = document.getElementById('subfolder-select');
    const submitContainer = document.getElementById('submit-container');
    const submitBtn = document.getElementById('submit-btn');
    const videoDisplay = document.getElementById('video-display');
    const videoSectionTitle = document.getElementById('video-section-title');
    const videoPlayersContainer = document.getElementById('video-players-container');

    let selectedFolder = null;
    let selectedSubfolder = null;

    // 文件夹选择事件 - 立即显示二级下拉
    folderSelect.addEventListener('change', function() {
      const folderName = this.value;
      
      // 重置submit按钮状态
      submitBtn.disabled = true;
      
      if (folderName) {
        selectedFolder = videoData.folders.find(f => f.name === folderName);
        
        if (selectedFolder && selectedFolder.subfolders.length > 0) {
          // 清空并填充子文件夹选项
          subfolderSelect.innerHTML = '<option value="">Please select a subfolder</option>';
          selectedFolder.subfolders.forEach(subfolder => {
            const option = document.createElement('option');
            option.value = subfolder.name;
            option.textContent = subfolder.name;
            subfolderSelect.appendChild(option);
          });
        } else {
          // 清空子文件夹选项
          subfolderSelect.innerHTML = '<option value="">Please select a subfolder</option>';
        }
      } else {
        // 清空子文件夹选项
        subfolderSelect.innerHTML = '<option value="">Please select a subfolder</option>';
        selectedFolder = null;
      }
      
      // 重置子文件夹选择
      selectedSubfolder = null;
      subfolderSelect.value = "";
    });

    // 子文件夹选择事件 - 控制submit按钮状态
     subfolderSelect.addEventListener('change', function() {
       const subfolderName = this.value;
       
       if (subfolderName && selectedFolder) {
         selectedSubfolder = selectedFolder.subfolders.find(sf => sf.name === subfolderName);
         
         if (selectedSubfolder && selectedSubfolder.videos.length > 0) {
           // 启用submit按钮
           submitBtn.disabled = false;
         } else {
           submitBtn.disabled = true;
         }
       } else {
         selectedSubfolder = null;
         submitBtn.disabled = true;
       }
     });

     // Submit按钮事件 - 播放所有视频
     submitBtn.addEventListener('click', function() {
       if (selectedSubfolder && selectedSubfolder.videos.length > 0) {
          // 暂停并清空当前播放的视频
          const videos = videoPlayersContainer.querySelectorAll('video');
          videos.forEach(video => {
            video.pause();
            video.currentTime = 0;
          });
          
          // 设置标题
          videoSectionTitle.textContent = `${selectedFolder.name} - ${selectedSubfolder.name}`;
          
          // 清空之前的视频和category信息
          videoPlayersContainer.innerHTML = '';
          
          // 移除之前的category容器
          const existingCategoryContainer = videoDisplay.querySelector('.bg-white .mt-4.p-3.bg-gray-100');
          if (existingCategoryContainer) {
            existingCategoryContainer.remove();
          }
          
          // 根据视频数量设置网格布局
          const videoCount = selectedSubfolder.videos.length;
          if (videoCount === 1) {
            videoPlayersContainer.className = 'grid gap-4 grid-cols-1';
          } else if (videoCount === 2) {
            videoPlayersContainer.className = 'grid gap-4 grid-cols-1 md:grid-cols-2';
          } else {
            videoPlayersContainer.className = 'grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
          }
          
          // 为每个视频创建播放器
          selectedSubfolder.videos.forEach((video, index) => {
            const videoWrapper = document.createElement('div');
            videoWrapper.className = 'bg-gray-50 rounded-lg p-3';
            
            const videoTitle = document.createElement('h3');
            videoTitle.className = 'text-sm font-medium text-gray-700 mb-2';
            videoTitle.textContent = video.name || `视频 ${index + 1}`;
            
            const videoElement = document.createElement('video');
            videoElement.controls = true;
            videoElement.autoplay = true;
            videoElement.muted = true;
            videoElement.loop = true;
            videoElement.className = 'w-full rounded-md shadow-sm';
            videoElement.style.maxHeight = '300px';
            videoElement.src = video.path;
            
            // 添加错误处理
            videoElement.onerror = function() {
              console.error('视频加载失败:', video.path);
              videoWrapper.style.display = 'none';
            };
            
            videoWrapper.appendChild(videoTitle);
            videoWrapper.appendChild(videoElement);
            videoPlayersContainer.appendChild(videoWrapper);
          });
          

          
          // 添加category信息到video-players-container下方
          const categoryContainer = document.createElement('div');
          categoryContainer.className = 'mt-4 p-3 bg-gray-100 rounded-lg';
          
          const categoryTitle = document.createElement('h4');
          categoryTitle.className = 'text-sm font-semibold text-gray-700 mb-1';
        //   categoryTitle.textContent = 'Scene Description:';
          
        //   const categoryText = document.createElement('p');
        //   categoryText.className = 'text-sm text-gray-600';
          const folderKey = selectedFolder.name;
          const subfolderKey = selectedSubfolder.name;
          if (categoryData[folderKey] && categoryData[folderKey][subfolderKey]) {
            const category = categoryData[folderKey][subfolderKey].category;
            categoryTitle.textContent = category.replace(/_/g, ' ');
          } else {
            categoryTitle.textContent = 'Category not found';
          }
          
          categoryContainer.appendChild(categoryTitle);
        //   categoryContainer.appendChild(categoryText);
          videoDisplay.querySelector('.bg-white').appendChild(categoryContainer);
          
          // 显示视频区域
          videoDisplay.classList.remove('hidden');
          
          // 滚动到视频区域
        //    videoDisplay.scrollIntoView({ behavior: 'smooth' });
       }
     });
  });
</script>

<style>
  .video-tree-dropdown {
    margin-top: 30px;
    width: 100%;
  }
  
  /* 下拉菜单样式 */
  select {
    transition: all 0.2s ease-in-out;
  }
  
  select:focus {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
  }
  
  /* 视频播放器样式 */
  video {
    transition: transform 0.2s ease-in-out;
  }
  
  video:hover {
    transform: scale(1.02);
  }
  
  /* 响应式网格调整 */
  @media (max-width: 768px) {
    .grid-cols-1.md\:grid-cols-2.lg\:grid-cols-3 {
      grid-template-columns: 1fr;
    }
    
    .grid-cols-1.md\:grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }
  
  /* 视频容器动画 */
  #video-display {
    animation: fadeIn 0.3s ease-in-out;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
